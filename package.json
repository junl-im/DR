{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build --base=/DR/",
    "build:github": "vite build --base=/DR/",
    "build:firebase": "vite build --base=/",
    "preview": "vite preview --host 0.0.0.0",
    "deploy:firebase": "npm run build:firebase && firebase deploy --only hosting,firestore",
    "deploy:hosting": "npm run build:firebase && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "typecheck": "tsc --noEmit",
    "check:assets": "node tools/check-no-svg.mjs",
    "check:health": "node tools/check-project-health.mjs",
    "check:kakao": "node tools/check-kakao-handoff.mjs",
    "check:content": "node tools/check-content-data.mjs",
    "report:images": "node tools/report-image-size.mjs",
    "check:workflows": "node tools/check-workflows.mjs",
    "atlas:manifest": "node tools/build-texture-atlas-manifest.mjs",
    "check:special-rules": "node tools/check-special-rules.mjs",
    "check:lobby-flow": "node tools/check-lobby-flow.mjs",
    "check:lobby-missions": "node tools/check-lobby-missions.mjs",
    "check:kakao-portrait": "node tools/check-kakao-portrait.mjs",
    "check:exit-scroll": "node tools/check-exit-scroll.mjs"
  },
  "dependencies": {
    "@esotericsoftware/spine-pixi-v8": "^4.3.7",
    "firebase": "^12.15.0",
    "gsap": "^3.15.0",
    "howler": "^2.2.4",
    "pixi.js": "^8.11.0",
    "vite": "latest"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  },
  "version": "1.0.16"
}
